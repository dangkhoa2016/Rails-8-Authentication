
<nav aria-label="breadcrumb" class='mb-4'>
  <ol class="breadcrumb">
    <li class="breadcrumb-item">
      <%= link_to root_path, class: 'link-body-emphasis border-bottom home' do %>
        <i class='bi bi-house'></i>
        <span class="visually-hidden">Home</span>
      <% end %>
    </li>
    <% if controller.action_name == 'index' %>
      <li class="bi breadcrumb-item active" aria-current="page"><%= controller_name.titleize %></li>
    <% elsif devise_controller? %>
      <li class="bi breadcrumb-item" aria-current="page">
        <%= controller_name.titleize %>
      </li>
      <li class="bi breadcrumb-item active" aria-current="page">
        <%= controller.action_name.titleize %>
      </li>
    <% elsif controller_name == 'static_pages' %>
      <li class="bi breadcrumb-item active" aria-current="page">
        <%= controller.action_name.titleize %>
      </li>
    <% else %>
      <li class="bi breadcrumb-item"><%= link_to controller_name.titleize, send("#{controller_name}_path"), class: 'link-body-emphasis' %></li>
      <li class="bi breadcrumb-item active" aria-current="page">
        <%= controller.action_name.titleize %>
      </li>
    <% end %>
  </ol>
</nav>
